<Window x:Class="DITool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DITool"
        mc:Ignorable="d"
        Title="Disney Infinity - NFC Tool" Height="650" Width="720" WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Background="#FF4C4C4C" Icon="/icon.ico">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/FlatComboBox.xaml" />
                <ResourceDictionary Source="/Styles/FlatButton.xaml" />
                <ResourceDictionary Source="/Styles/FlatTextBox.xaml" />
                <ResourceDictionary Source="/Styles/FlatCheckBox.xaml" />
                <ResourceDictionary Source="/Styles/FlatScrollBar.xaml" />
                <ResourceDictionary Source="/Styles/FlatScrollViewer.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="221*"/>
            <RowDefinition Height="83*"/>
            <RowDefinition Height="328*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>

        <GroupBox x:Name="gbConversion" Header="Conversion" Foreground="#FFD0D0D0" BorderBrush="#FF484848" Margin="10,0,10,0" Grid.Row="0">
            <Grid>
                <ComboBox x:Name="cbConversionType" HorizontalAlignment="Left" Width="200" VerticalAlignment="Top" Margin="20,20,0,0" Style="{StaticResource ComboBoxFlatStyle}">
                    <ComboBoxItem Content="Convert Folder" IsSelected="True"/>
                    <ComboBoxItem Content="Convert Single File" />
                </ComboBox>
                <TextBox x:Name="tbPath" Text="..." Style="{StaticResource TextBoxFlatStyle}" HorizontalAlignment="Left" Margin="20,55,0,0"  VerticalAlignment="Top" Width="563" FontFamily="Consolas" IsReadOnly="True" />
                <Button x:Name="btBrowse" Content="Browse" Style="{StaticResource ButtonFlatStyle}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,55,20,0" />
                <GroupBox x:Name="gbOutputFormats" Header="Output Format" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20,88,0,0" Height="86" Width="160" BorderBrush="#FF484848">
                    <Grid>
                        <CheckBox x:Name="chExtBin" Content="BIN" Style="{StaticResource CheckBoxFlatStyle}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,10,0,0" />
                        <CheckBox x:Name="chExtMct" Content="MCT" Style="{StaticResource CheckBoxFlatStyle}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,35,0,0" />
                        <CheckBox x:Name="chExtDmp" Content="DMP" Style="{StaticResource CheckBoxFlatStyle}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="70,35,0,0" />
                        <CheckBox x:Name="chExtMfd" Content="MFD" Style="{StaticResource CheckBoxFlatStyle}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="70,10,0,0" />
                    </Grid>
                </GroupBox>
                <GroupBox x:Name="gbOptions" Header="Options" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="200,88,0,0" Height="86" Width="216" BorderBrush="#FF484848">
                    <Grid>
                        <CheckBox x:Name="chComputeKeyA" Content="Compute KeyA" Style="{StaticResource CheckBoxFlatStyle}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,10,0,0" />
                        <CheckBox x:Name="chGenerateKeyFile" Content="Generate nfc-tools keys file" Style="{StaticResource CheckBoxFlatStyle}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,35,0,0" />
                    </Grid>
                </GroupBox>
            </Grid>
        </GroupBox>
        <GroupBox Header="Commands" Margin="10,0,10,0" BorderBrush="#FF484848" Foreground="#FFD0D0D0" Grid.Row="1">
            <Grid>
                <Button x:Name="btConvert" Content="Convert" Style="{StaticResource ButtonFlatStyle}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="20,0,0,0" Height="29" Padding="10,1,10,1" FontSize="14" IsEnabled="False"/>
                <Button x:Name="btClearConsole" Content="Clear Console" Style="{StaticResource ButtonFlatStyle}" HorizontalAlignment="Left" VerticalAlignment="Center" Height="29" Padding="10,1,10,1" FontSize="14" Margin="323,0,0,0"/>
                <Button x:Name="btExportLog" Content="Export Log" Style="{StaticResource ButtonFlatStyle}" HorizontalAlignment="Left" VerticalAlignment="Center" Height="29" Padding="10,1,10,1" FontSize="14" Margin="234,0,0,0" RenderTransformOrigin="0.093,0.516"/>
                <Button x:Name="btExit" Content="Exit" Style="{StaticResource ButtonFlatStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Height="29" Padding="10,1,10,1" FontSize="14" Margin="0,0,20,0"/>
                <Button x:Name="btAbout" Content="About" Style="{StaticResource ButtonFlatStyle}" HorizontalAlignment="Left" VerticalAlignment="Center" Height="29" Padding="10,1,10,1" FontSize="14" Margin="550,0,0,0"/>
                <Button x:Name="btStop" Content="Stop" Style="{StaticResource ButtonFlatStyle}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="91,0,0,0" Height="29" Padding="10,1,10,1" FontSize="14"/>
            </Grid>
        </GroupBox>
        <GroupBox Header="Console" Margin="10,0,10,5" Foreground="#FFD0D0D0" BorderBrush="#FF484848" Grid.Row="2" ScrollViewer.CanContentScroll="True">
            <ScrollViewer x:Name="svConsole" Style="{StaticResource styleScrollViewer}" HorizontalScrollBarVisibility="Auto" Padding="6,6,6,6" Foreground="{x:Null}" UseLayoutRounding="False" CanContentScroll="True" VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="tbConsole" Text="..." FontFamily="Consolas" Foreground="White" Focusable="True" />
            </ScrollViewer>
        </GroupBox>

        <ProgressBar x:Name="pbProgress" Grid.Row="3" Value="30" Background="#FF4C4C4C" BorderBrush="{x:Null}">
            <ProgressBar.Foreground>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF6A77E8" Offset="0.154"/>
                    <GradientStop Offset="0" Color="#FFABB4FF"/>
                </LinearGradientBrush>
            </ProgressBar.Foreground>
        </ProgressBar>

        <local:AboutControl x:Name="About" Grid.RowSpan="4" Visibility="Hidden" />

    </Grid>
</Window>
