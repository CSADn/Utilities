<UserControl x:Name="About" x:Class="DITool.AboutControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" ScrollViewer.VerticalScrollBarVisibility="Disabled" Grid.IsSharedSizeScope="True">
    <Border x:Name="dpOverlay" Cursor="Hand" Width="{Binding ElementName=About, Path=Width}" Height="{Binding ElementName=About, Path=Height}">
        <Border.Background>
            <SolidColorBrush Color="#FF4E4E4E" Opacity="0.9"/>
        </Border.Background>
        <Grid>
            <Image HorizontalAlignment="Center" Width="400" VerticalAlignment="Top" Margin="0,60,0,0" Source="{DynamicResource DisneyLogo}" />
            <!--<local:AboutControl HorizontalAlignment="Center" VerticalAlignment="Center" Height="205" Margin="0,90,0,0" Width="500" />-->
            <Border Background="#FFA5A5A5" CornerRadius="6,6,6,6" Opacity="0.8" BorderThickness="2,2,2,2" BorderBrush="White" Width="500" Height="204" VerticalAlignment="Top" Margin="0,250,0,0">
                <StackPanel>
                    <Label Name="lbTitle" Content="- DITool {v} - 2023 -" HorizontalAlignment="Center" VerticalAlignment="Top" FontFamily="{DynamicResource PoppinsSemiBold}" Foreground="#FF373737" FontSize="20" >
                        <Label.Effect>
                            <DropShadowEffect Color="#FFBDBDBD"/>
                        </Label.Effect>
                    </Label>
                    <Label Content="{}{zantzue}" HorizontalAlignment="Center" VerticalAlignment="Top" FontFamily="{DynamicResource PoppinsSemiBold}" Foreground="White" />
                    <Label Content="Idea + Research + Prototype + Test + Tutorial" HorizontalAlignment="Center" FontFamily="{DynamicResource PoppinsRegular}" Foreground="#FF5D5D5D" VerticalAlignment="Top" Margin="0,-13,0,0" />
                    <Label Content="{}{ADn06}" HorizontalAlignment="Center" VerticalAlignment="Top" FontFamily="{DynamicResource PoppinsSemiBold}" Foreground="White" Margin="0,5,0,0" Background="#00000000" />
                    <Label Content="Tool Development" HorizontalAlignment="Center" FontFamily="{DynamicResource PoppinsRegular}" Foreground="#FF5D5D5D" VerticalAlignment="Top" Margin="0,-13,0,0" />
                    <Label Name="lbTutorial" Content="++ Tutorial ++" HorizontalAlignment="Center" VerticalAlignment="Top" FontFamily="{DynamicResource PoppinsBold}" FontSize="14" Cursor="Hand" Margin="0,12,0,0">
                        <Label.Style>
                            <Style TargetType="Label">
                                <Setter Property="Foreground" Value="#FF6500FF" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="Red" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Label.Style>
                    </Label>
                    <Label Content="+++ This tool was made just for education purposes +++" HorizontalAlignment="Center" VerticalAlignment="Top" FontFamily="{DynamicResource PoppinsRegular}" Foreground="Red" FontSize="10" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</UserControl>
