<Window x:Class="TVPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        xmlns:vm="clr-namespace:TVPlayer.ViewModels"
        xmlns:conv="clr-namespace:TVPlayer.Converters"
        Title="{Binding Player.CurrentChannelName, Converter={StaticResource ChannelTitle}}"
        Height="720" Width="1280"
        MinHeight="480" MinWidth="800"
        Background="#1a1a2e"
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <!-- Converters -->
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToVisibilityConverter x:Key="InvBoolToVis" Invert="True"/>
        <conv:PlayPauseIconConverter   x:Key="PlayPauseIcon"/>
        <conv:MuteIconConverter        x:Key="MuteIcon"/>
        <conv:FloatToDoubleConverter   x:Key="FloatToDouble"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisInv" Invert="True"/>

        <!-- Dark colour palette -->
        <SolidColorBrush x:Key="PrimaryBg"    Color="#1a1a2e"/>
        <SolidColorBrush x:Key="SecondaryBg"  Color="#16213e"/>
        <SolidColorBrush x:Key="SurfaceBg"    Color="#0f3460"/>
        <SolidColorBrush x:Key="AccentBrush"  Color="#e94560"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#eaeaea"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#8a8a9a"/>
        <SolidColorBrush x:Key="BorderColor"  Color="#2a2a4a"/>

        <!-- Base button style -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="Foreground"   Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"  Value="Transparent"/>
            <Setter Property="FontSize"     Value="16"/>
            <Setter Property="Padding"      Value="8,4"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2a2a4a"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#e94560"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Accent button -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
            <Setter Property="Background"  Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
        </Style>

        <!-- Slider style (seek bar + volume) -->
        <Style x:Key="PlayerSlider" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="{StaticResource AccentBrush}" Height="4" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="12" Height="12" Fill="White"
                                                         Effect="{x:Null}"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="#2a2a4a" Height="4" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox style -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background"   Value="#0f1a30"/>
            <Setter Property="Foreground"   Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"  Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="6,4"/>
            <Setter Property="CaretBrush"   Value="White"/>
        </Style>

        <!-- ComboBox style -->
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background"      Value="#0f1a30"/>
            <Setter Property="Foreground"      Value="#0f1a30"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,4"/>
        </Style>

        <!-- Channel list item style -->
        <Style x:Key="ChannelItem" TargetType="ListBoxItem">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
            <Setter Property="Padding"     Value="8,6"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1e2a4a"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SurfaceBg}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Playlist tab item style -->
        <Style x:Key="PlaylistItem" TargetType="ListBoxItem">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="{StaticResource TextMuted}"/>
            <Setter Property="Padding"     Value="10,8"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SurfaceBg}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ScrollBar minimal style -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Toolbar -->
            <RowDefinition Height="48"/>
            <!-- Main content -->
            <RowDefinition Height="*"/>
            <!-- Status bar -->
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <!-- ===== TOOLBAR ===== -->
        <Border x:Name="Toolbar" Grid.Row="0" Background="{StaticResource SecondaryBg}"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
            <DockPanel Margin="8,0" VerticalAlignment="Center">

                <!-- Logo / Title -->
                <TextBlock DockPanel.Dock="Left" Text="📺 TV Player"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="16" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,16,0"/>

                <!-- Open file -->
                <Button DockPanel.Dock="Left"
                        Style="{StaticResource AccentButton}"
                        Command="{Binding OpenFileCommand}"
                        Content="📂 Open File"
                        ToolTip="Open a local M3U/M3U8 playlist"
                        Margin="0,0,8,0"/>

                <!-- URL input + load -->
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource AccentButton}"
                        Command="{Binding OpenUrlCommand}"
                        Content="⏎ Load"
                        Margin="4,0,0,0"/>

                <TextBox DockPanel.Dock="Right"
                         Style="{StaticResource DarkTextBox}"
                         Text="{Binding UrlInput, UpdateSourceTrigger=PropertyChanged}"
                         Width="350"
                         VerticalAlignment="Center"
                         ToolTip="Enter a playlist URL (M3U8) or a direct stream URL">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding OpenUrlCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <TextBlock DockPanel.Dock="Right" Text="URL / Stream: "
                           Foreground="{StaticResource TextMuted}"
                           VerticalAlignment="Center" Margin="8,0,4,0"/>

                <!-- Loading indicator -->
                <TextBlock Text="⏳ Loading…"
                           Foreground="{StaticResource AccentBrush}"
                           VerticalAlignment="Center" Margin="16,0,0,0"
                           Visibility="{Binding IsLoadingPlaylist, Converter={StaticResource BoolToVis}}"/>
            </DockPanel>
        </Border>

        <!-- ===== MAIN CONTENT ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Sidebar: playlists + channels -->
                <ColumnDefinition x:Name="SidebarColumn" Width="280" MinWidth="200" MaxWidth="500"/>
                <ColumnDefinition Width="4"/>
                <!-- Video area -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── SIDEBAR ── -->
            <Grid x:Name="Sidebar" Grid.Column="0" Background="{StaticResource SecondaryBg}">
                <Grid.RowDefinitions>
                    <!-- Playlist tabs -->
                    <RowDefinition Height="Auto"/>
                    <!-- Search + Group filter -->
                    <RowDefinition Height="Auto"/>
                    <!-- Channel list -->
                    <RowDefinition Height="*"/>
                    <!-- Channel count -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Playlist list -->
                <Border Grid.Row="0" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto" MaxHeight="120"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="PLAYLISTS"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="10" FontWeight="Bold"
                                   Margin="10,8,10,4"/>

                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding Playlists}"
                                 SelectedItem="{Binding SelectedPlaylist}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource PlaylistItem}"/>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock FontSize="10"
                                                       Foreground="{StaticResource TextMuted}">
                                                <Run Text="{Binding Channels.Count, Mode=OneWay}"/>
                                                <Run Text=" channels"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Style="{StaticResource IconButton}"
                                                Content="✕"
                                                FontSize="10"
                                                Padding="4,2"
                                                Foreground="{StaticResource TextMuted}"
                                                Command="{Binding DataContext.RemovePlaylistCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Search + Group filter -->
                <StackPanel Grid.Row="1" Margin="8,8,8,4">
                    <TextBox Style="{StaticResource DarkTextBox}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,6">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    <!-- Hint text overlay -->
                    <Grid Margin="0,-30,0,6" IsHitTestVisible="False">
                        <TextBlock Text="🔍 Search channels…"
                                   Name="tbSearch"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="12" Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding SearchText,
                                        Converter={StaticResource NullToVisInv}}"/>
                    </Grid>

                    <ComboBox Style="{StaticResource DarkCombo}"
                              ItemsSource="{Binding Groups}"
                              SelectedItem="{Binding SelectedGroup}"/>
                </StackPanel>

                <!-- Channel list -->
                <ListBox Grid.Row="2"
                         ItemsSource="{Binding FilteredChannels}"
                         SelectedItem="{Binding SelectedChannel}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource ChannelItem}"/>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Logo -->
                                <Border Grid.Column="0" Width="32" Height="32"
                                        CornerRadius="4"
                                        Background="{StaticResource SurfaceBg}"
                                        ClipToBounds="True">
                                    <Image Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"
                                           Source="{Binding LogoUrl, TargetNullValue={x:Null}}"/>
                                </Border>

                                <!-- Name + group -->
                                <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="13"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Group}"
                                               FontSize="10"
                                               Foreground="{StaticResource TextMuted}"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Channel count footer -->
                <Border Grid.Row="3"
                        Background="{StaticResource PrimaryBg}"
                        Padding="8,4">
                    <TextBlock Foreground="{StaticResource TextMuted}" FontSize="11">
                        <Run Text="{Binding FilteredChannels.Count, Mode=OneWay, FallbackValue=0}"/>
                        <Run Text=" channels"/>
                    </TextBlock>
                </Border>
            </Grid>

            <!-- Splitter -->
            <GridSplitter x:Name="Splitter" Grid.Column="1" Width="4"
                          Background="{StaticResource BorderColor}"
                          VerticalAlignment="Stretch"
                          HorizontalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- ── VIDEO AREA ── -->
            <Grid Grid.Column="2" Background="Black">
                <Grid.RowDefinitions>
                    <!-- Video surface -->
                    <RowDefinition Height="*"/>
                    <!-- Controls overlay -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- VLC Video View – wrapped in a ContentControl so it can be
                     reparented to the fullscreen window without being destroyed -->
                <ContentControl Grid.Row="0" x:Name="VideoContainer" Background="Black"/>

                <!-- Placeholder when nothing is playing -->
                <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding Player.IsStopped, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="📺" FontSize="64" HorizontalAlignment="Center"/>
                    <TextBlock Text="Select a channel or open a playlist"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="16" HorizontalAlignment="Center"
                               Margin="0,12,0,0"/>
                </StackPanel>

                <!-- Buffering overlay -->
                <Grid Grid.Row="0" Background="#80000000"
                      Visibility="{Binding Player.IsBuffering, Converter={StaticResource BoolToVis}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="⏳" FontSize="40" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Player.StatusMessage}"
                                   Foreground="White" FontSize="14"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- ── PLAYER CONTROLS ── -->
                <Border x:Name="PlayerControls" Grid.Row="1"
                        Background="{StaticResource SecondaryBg}"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="0,1,0,0"
                        Padding="12,8">
                    <StackPanel>

                        <!-- Channel title + copy URL button -->
                        <Grid Margin="0,0,0,6"
                              Visibility="{Binding Player.CurrentChannelName,
                                   Converter={StaticResource NullToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{Binding Player.CurrentChannelName}"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontSize="13" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"/>

                            <!-- URL text (truncated) -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Player.CurrentChannelUrl}"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="10" FontFamily="Consolas"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="220"
                                       VerticalAlignment="Center"
                                       Margin="8,0,4,0"
                                       ToolTip="{Binding Player.CurrentChannelUrl}"/>

                            <!-- Copy button -->
                            <Button Grid.Column="2"
                                    Style="{StaticResource IconButton}"
                                    Command="{Binding Player.CopyUrlToClipboardCommand}"
                                    ToolTip="Copy stream URL to clipboard"
                                    Padding="6,3">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📋" FontSize="13"/>
                                    <TextBlock Text="{Binding Player.CopyUrlFeedback}"
                                               FontSize="11"
                                               Foreground="#4caf50"
                                               FontWeight="SemiBold"
                                               Margin="4,0,0,0"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding Player.CopyUrlFeedback,
                                                    Converter={StaticResource NullToVis}}"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Seek bar row -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{Binding Player.TimeDisplay}"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="11" VerticalAlignment="Center"
                                       Margin="0,0,8,0" FontFamily="Consolas"/>

                            <Slider Grid.Column="1"
                                    x:Name="SeekSlider"
                                    Style="{StaticResource PlayerSlider}"
                                    Minimum="0" Maximum="1"
                                    Value="{Binding Player.Position,
                                             Converter={StaticResource FloatToDouble},
                                             Mode=TwoWay}"
                                    VerticalAlignment="Center"
                                    IsMoveToPointEnabled="True"
                                    Thumb.DragStarted="SeekSlider_DragStarted"
                                    Thumb.DragCompleted="SeekSlider_DragCompleted"/>

                            <TextBlock Grid.Column="2"
                                       Text="{Binding Player.DurationDisplay}"
                                       Foreground="{StaticResource TextMuted}"
                                       FontSize="11" VerticalAlignment="Center"
                                       Margin="8,0,0,0" FontFamily="Consolas"/>
                        </Grid>

                        <!-- Buttons row -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left: volume -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Button Style="{StaticResource IconButton}"
                                        Content="{Binding Player.IsMuted, Converter={StaticResource MuteIcon}}"
                                        Command="{Binding Player.ToggleMuteCommand}"
                                        ToolTip="Toggle mute (M)"/>
                                <Slider Style="{StaticResource PlayerSlider}"
                                        Minimum="0" Maximum="200"
                                        Value="{Binding Player.Volume,
                                                 Converter={StaticResource FloatToDouble},
                                                 Mode=TwoWay}"
                                        Width="90" VerticalAlignment="Center"
                                        Margin="4,0,0,0"
                                        ToolTip="Volume"/>
                                <TextBlock Foreground="{StaticResource TextMuted}"
                                           FontSize="11" VerticalAlignment="Center"
                                           Margin="6,0,0,0">
                                    <Run Text="{Binding Player.Volume, StringFormat={}{0:0}, Mode=OneWay}"/>
                                    <Run Text="%"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- Centre: transport buttons -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <Button Style="{StaticResource IconButton}"
                                        Content="⏪" FontSize="18"
                                        Command="{Binding Player.SeekBackwardCommand}"
                                        ToolTip="Rewind 10 s"/>
                                <Button Style="{StaticResource IconButton}"
                                        Content="⏹" FontSize="18"
                                        Command="{Binding Player.StopCommand}"
                                        ToolTip="Stop" Margin="4,0"/>
                                <Button Style="{StaticResource AccentButton}"
                                        FontSize="22" Width="48" Height="40"
                                        Command="{Binding Player.PauseCommand}"
                                        ToolTip="Pause"
                                        Visibility="{Binding Player.IsPlaying, Converter={StaticResource BoolToVis}}"
                                        Content="⏸"/>
                                <Button Style="{StaticResource AccentButton}"
                                        FontSize="22" Width="48" Height="40"
                                        Command="{Binding Player.PlayCommand}"
                                        ToolTip="Play"
                                        Visibility="{Binding Player.IsPaused, Converter={StaticResource BoolToVis}}"
                                        Content="▶"/>
                                <Button Style="{StaticResource IconButton}"
                                        Content="⏩" FontSize="18"
                                        Command="{Binding Player.SeekForwardCommand}"
                                        ToolTip="Forward 10 s" Margin="4,0,0,0"/>
                            </StackPanel>

                            <!-- Right: full-screen -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                        HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Style="{StaticResource IconButton}"
                                        Content="⛶"
                                        FontSize="18"
                                        Command="{Binding Player.ToggleFullScreenCommand}"
                                        ToolTip="Toggle full screen (F11)"
                                        Click="FullScreenButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ===== STATUS BAR ===== -->
        <Border x:Name="StatusBar" Grid.Row="2"
                Background="{StaticResource PrimaryBg}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,1,0,0"
                Padding="12,0">
            <DockPanel VerticalAlignment="Center">
                <TextBlock DockPanel.Dock="Right"
                           Text="LibVLC powered · H.264 · H.265 · HLS · MPEG-TS"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="10"/>
                <TextBlock Text="{Binding Player.StatusMessage}"
                           Foreground="{StaticResource TextMuted}"
                           FontSize="11"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
