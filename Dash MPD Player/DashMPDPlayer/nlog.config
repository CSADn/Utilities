<?xml version="1.0" encoding="utf-8"?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwExceptions="false"
      internalLogFile=""
      internalLogLevel="Off">

  <targets>
    <target name="console"
            xsi:type="ColoredConsole"
            layout="${longdate} | ${level:uppercase=true:padding=-5} | ${logger:shortName=true} | ${message}${exception:format=toString}"
            useDefaultRowHighlightingRules="true" />

    <target name="file"
            xsi:type="File"
            fileName="${basedir}/logs/dash-player-${shortdate}.log"
            layout="${longdate} | ${level:uppercase=true:padding=-5} | ${logger} | ${message}${exception:format=toString}"
            maxArchiveFiles="30"
            archiveAboveSize="10485760"
            archiveNumbering="Sequence"
            concurrentWrites="false"
            keepFileOpen="false"
            encoding="utf-8" />
  </targets>

  <rules>
    <logger name="*" minlevel="Trace" writeTo="console,file" />
  </rules>
</nlog>
